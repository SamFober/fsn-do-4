        display: inline-block;
        padding: 3px 6px;
        margin-right: 5px;
        border-radius: 4px;
        background-color: var(--primary-color);
        color: white;
        font-size: 0.75rem;
        font-weight: 500;
    }
    
    .hall-preview-large {
        margin-top: 20px;
        width: 100%;
        display: flex;
        flex-direction: column;
        align-items: center;
    }
    
    .hall-screen {
        width: 100%;
        max-width: 600px;
        padding: 10px;
        text-align: center;
        background-color: #111;
        color: white;
        margin-bottom: 20px;
        border-radius: 4px;
    }
    
    .hall-seats {
        display: flex;
        flex-direction: column;
        gap: 5px;
        align-items: center;
    }
    
    .hall-seat-row {
        display: flex;
        gap: 5px;
    }
    
    .hall-seat-mini {
        width: 20px;
        height: 20px;
        background-color: var(--primary-color);
        border-radius: 3px;
    }
    
    .seating-layout {
        margin-top: 20px;
        width: 100%;
        display: flex;
        flex-direction: column;
        align-items: center;
    }
    
    .screen-label {
        width: 100%;
        max-width: 600px;
        padding: 10px;
        text-align: center;
        background-color: #111;
        color: white;
        margin-bottom: 20px;
        border-radius: 4px;
    }
    
    .hall-seat {
        width: 20px;
        height: 20px;
        background-color: var(--primary-color);
        border-radius: 3px;
    }
    
    .row-letter {
        display: inline-block;
        padding: 3px 6px;
        margin-right: 5px;
        border-radius: 4px;
        background-color: var(--primary-color);
        color: white;
        font-size: 0.75rem;
        font-weight: 500;
    }
</style>

@code {
    private bool isLoading = true;
    private string? errorMessage = null;
    private string? successMessage = null;
    
    // Hall data
    private List<HallViewModel> halls = new();
    private List<HallViewModel> filteredHalls => GetFilteredHalls();
    
    // Filters
    private string searchQuery = "";
    private string selectedStatus = "";
    private string sortBy = "id";
    
    // Modal states
    private bool showAddEditModal = false;
    private bool showDeleteModal = false;
    private bool showViewModal = false;
    private HallViewModel? editingHall = null;
    private HallViewModel? deletingHall = null;
    private HallViewModel? viewingHall = null;
    
    // Form data
    private HallFormModel currentHall = new();
    
    // Random for generating sample data
    private Random random = new Random();
    
    // Pagination
    private int currentPage = 1;
    private int pageSize = 10;
    private int totalPages => (int)Math.Ceiling(filteredHalls.Count / (double)pageSize);
    
    private List<HallViewModel> paginatedHalls => filteredHalls
        .Skip((currentPage - 1) * pageSize)
        .Take(pageSize)
        .ToList();
    
    protected override async Task OnInitializedAsync()
    {
        try
        {
            isLoading = true;
            await LoadData();
            ApplyFilters();
        }
        catch (Exception ex)
        {
            errorMessage = $"Error loading halls: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }
    
    private async Task LoadData()
    {
        try
        {
            // Fetch halls data from the API
            var apiResponse = await Http.GetFromJsonAsync<List<ApiHallResponse>>("api/halls");
            
            if (apiResponse != null)
            {
                // Map API response to our view model
                halls = apiResponse.Select(h => new HallViewModel
                {
                    Id = h.Id,
                    Name = h.Name,
                    Capacity = h.Capacity,
                    // Use actual values from API rather than calculating
                    Rows = h.Rows,
                    SeatsPerRow = h.SeatsPerRow,
                    IsActive = h.IsActive,
                    Description = h.Description ?? $"Hall with {h.Capacity} seats.", // Use API description or fallback
                    // Set layout based on name for visualization
                    Layout = h.Name.Contains("IMAX") ? "IMAX" : (h.Name.Contains("4DX") ? "4DX" : "Standard"),
                    CreatedAt = h.CreatedAt,
                    UpdatedAt = h.UpdatedAt,
                    Seats = h.Seats?.Select(s => new SeatInfo 
                    { 
                        Id = s.Id, 
                        RowNumber = s.RowNumber, 
                        SeatNumber = s.SeatNumber 
                    }).ToList() ?? new List<SeatInfo>()
                }).ToList();
            }
            else
            {
                errorMessage = "Failed to load halls from API";
                halls = new List<HallViewModel>();
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Error loading halls: {ex.Message}";
            halls = new List<HallViewModel>();
        }
    }
    
    private void ApplyFilters()
    {
        // The GetFilteredHalls method will use these filters
        // Simply calling StateHasChanged will cause the UI to refresh
        // and use the GetFilteredHalls method with the current filters
        
        // Force a UI refresh
        StateHasChanged();
    }
    
    private void ResetFilters()
    {
        searchQuery = "";
        selectedStatus = "";
        sortBy = "id";
        ApplyFilters();
    }
    
    private async Task HandleSearchKeyUp(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            await Task.Delay(1); // Ensure the search query is updated
            ApplyFilters();
        }
    }
    
    private void AddNewHall()
    {
        editingHall = null;
        currentHall = new HallFormModel
        {
            IsActive = true,
            Layout = "Standard",
            Capacity = 100
        };
        showAddEditModal = true;
    }
    
    private void EditHall(HallViewModel hall)
    {
        editingHall = hall;
        currentHall = new HallFormModel
        {
            Id = hall.Id,
            Name = hall.Name,
            Capacity = hall.Capacity,
            Layout = hall.Layout,
            Description = hall.Description,
            IsActive = hall.IsActive,
            Rows = hall.Rows,
            SeatsPerRow = hall.SeatsPerRow,
        };
        showAddEditModal = true;
    }
    
    private void ViewHall(HallViewModel hall)
    {
        viewingHall = hall;
        showViewModal = true;
    }
    
    private void DeleteHall(HallViewModel hall)
    {
        deletingHall = hall;
        showDeleteModal = true;
    }
    
    private async Task SaveHall()
    {
        try
        {
            if (editingHall == null)
            {
                // Creating a new hall
                var createRequest = new
                {
                    Name = currentHall.Name,
                    Rows = currentHall.Rows,
                    SeatsPerRow = currentHall.SeatsPerRow,
                    IsActive = currentHall.IsActive,
                    Description = currentHall.Description
                };

                // Call the API to create the hall
                var response = await Http.PostAsJsonAsync("api/halls", createRequest);
                
                if (response.IsSuccessStatusCode)
                {
                    var createdHall = await response.Content.ReadFromJsonAsync<ApiHallResponse>();
                    successMessage = $"Hall '{currentHall.Name}' has been created successfully.";
                    
                    // Refresh the data
                    await LoadData();
                }
                else
                {
                    var errorContent = await response.Content.ReadAsStringAsync();
                    throw new Exception($"Failed to create hall. Status: {response.StatusCode}, Error: {errorContent}");
                }
            }
            else
            {
                // Updating an existing hall
                var updateRequest = new
                {
                    Name = currentHall.Name,
                    Rows = currentHall.Rows,
                    SeatsPerRow = currentHall.SeatsPerRow,
                    IsActive = currentHall.IsActive,
                    Description = currentHall.Description
                };
                
                // Call the API to update the hall
                var response = await Http.PutAsJsonAsync($"api/halls/{editingHall.Id}", updateRequest);
                
                if (response.IsSuccessStatusCode)
                {
                    successMessage = $"Hall '{currentHall.Name}' has been updated successfully.";
                    
                    // Refresh the data
                    await LoadData();
                }
                else
                {
                    var errorContent = await response.Content.ReadAsStringAsync();
                    throw new Exception($"Failed to update hall. Status: {response.StatusCode}, Error: {errorContent}");
                }
            }
            
            // Close the modal and refresh the list
            CloseModal();
            ApplyFilters();
        }
        catch (Exception ex)
        {
            errorMessage = $"Error saving hall: {ex.Message}";
        }
    }
    
    private async Task ConfirmDeleteHall()
    {
        if (deletingHall == null) return;
        
        try
        {
            // Call the API to delete the hall
            var response = await Http.DeleteAsync($"api/halls/{deletingHall.Id}");
            
            if (response.IsSuccessStatusCode)
            {
                successMessage = $"Hall '{deletingHall.Name}' has been deleted successfully.";
                
                // Refresh the data
                await LoadData();
            }
            else
            {
                var errorContent = await response.Content.ReadAsStringAsync();
                throw new Exception($"Failed to delete hall. Status: {response.StatusCode}, Error: {errorContent}");
            }
            
            CloseModal();
            ApplyFilters();
        }
        catch (Exception ex)
        {
            errorMessage = $"Error deleting hall: {ex.Message}";
        }
    }
    
    private void CloseModal()
    {
        showAddEditModal = false;
        showDeleteModal = false;
        showViewModal = false;
        editingHall = null;
        deletingHall = null;
        viewingHall = null;
        currentHall = new HallFormModel();
    }
    
    // Filter halls based on search and status
    private List<HallViewModel> GetFilteredHalls()
    {
        // Start with all halls
        var query = halls.AsQueryable();
        
        // Apply search query
        if (!string.IsNullOrWhiteSpace(searchQuery))
        {
            query = query.Where(h => 
                h.Name.Contains(searchQuery, StringComparison.OrdinalIgnoreCase) ||
                h.Layout.Contains(searchQuery, StringComparison.OrdinalIgnoreCase) ||
                (h.Description != null && h.Description.Contains(searchQuery, StringComparison.OrdinalIgnoreCase)));
        }
        
        // Apply status filter
        if (!string.IsNullOrWhiteSpace(selectedStatus))
        {
            bool isActive = selectedStatus == "true";
            query = query.Where(h => h.IsActive == isActive);
        }
        
        // Apply sorting
        query = sortBy switch
        {
            "name" => query.OrderBy(h => h.Name),
            "capacity" => query.OrderByDescending(h => h.Capacity),
            _ => query.OrderBy(h => h.Id)
        };
        
        // Return the filtered and sorted results
        return query.ToList();
    }
    
    // Hall view model
    private class HallViewModel
    {
        public int Id { get; set; }
        public string Name { get; set; } = "";
        public int Capacity { get; set; }
        public bool IsActive { get; set; }
        public DateTime CreatedAt { get; set; }
        public DateTime UpdatedAt { get; set; }
        public string? Description { get; set; }
        public int Rows { get; set; }
        public int SeatsPerRow { get; set; }
        public string Layout { get; set; } = "";
        public List<SeatInfo> Seats { get; set; } = new List<SeatInfo>();
    }
    
    // API response model from Hall controller
    private class ApiHallResponse
    {
        public int Id { get; set; }
        public string Name { get; set; } = "";
        public int Rows { get; set; }
        public int SeatsPerRow { get; set; }
        public int Capacity { get; set; }
        public bool IsActive { get; set; }
        public string? Description { get; set; }
        public DateTime CreatedAt { get; set; }
        public DateTime UpdatedAt { get; set; }
        public List<ApiSeatInfo>? Seats { get; set; }
    }
    
    public class ApiSeatInfo
    {
        public int Id { get; set; }
        public int RowNumber { get; set; }
        public int SeatNumber { get; set; }
    }
    
    public class SeatInfo
    {
        public int Id { get; set; }
        public int RowNumber { get; set; }
        public int SeatNumber { get; set; }
    }
    
    // Form model for hall creation/editing
    private class HallFormModel
    {
        [Required(ErrorMessage = "Hall name is required")]
        [StringLength(100, ErrorMessage = "Hall name cannot exceed 100 characters")]
        public string Name { get; set; } = "";
        
        [Required(ErrorMessage = "Capacity is required")]
        [Range(1, 1000, ErrorMessage = "Capacity must be between 1 and 1000")]
        public int Capacity { get; set; } = 100;
        
        public string? Description { get; set; }
        public int Rows { get; set; } = 10;
        public int SeatsPerRow { get; set; } = 10;
        public bool IsActive { get; set; } = true;
        public int Id { get; set; }
        public string Layout { get; set; } = "Standard";
    }
    
    private void HandlePageChange(int page)
    {
        currentPage = page;
        StateHasChanged();
    }
    
    private void HandlePageSizeChange(int size)
    {
        pageSize = size;
        currentPage = 1; // Reset to first page when changing page size
        StateHasChanged();
    }
} 