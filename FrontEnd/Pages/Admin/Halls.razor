@page "/admin/halls"
@layout AdminLayout
@using FrontEnd.Models
@using System.ComponentModel.DataAnnotations
@using FrontEnd.Components
@inject HttpClient Http
@inject IJSRuntime JS

<PageTitle>Halls Management - Cinemagia</PageTitle>

<div class="admin-container">
    <div class="page-header">
        <h1 class="page-title">Hall Management</h1>
        <p class="page-description">Manage cinema halls and seating arrangements</p>
    </div>
    
    @if (isLoading)
    {
        <div class="loading-container">
            <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden">Loading...</span>
            </div>
            <p>Loading halls data...</p>
        </div>
    }
    else
    {
        <div class="filters-bar">
            <div class="search-box">
                <i class="fas fa-search search-icon"></i>
                <input 
                    type="text" 
                    class="form-control"
                    placeholder="Search halls..." 
                    @bind="searchQuery" 
                    @bind:event="oninput" 
                    @onkeyup="HandleSearchKeyUp" />
            </div>
            
            <div class="filters-section">
                <select class="filter-select" @bind="selectedStatus">
                    <option value="">All Status</option>
                    <option value="true">Active</option>
                    <option value="false">Inactive</option>
                </select>
                
                <select class="filter-select" @bind="sortBy">
                    <option value="id">Sort by ID</option>
                    <option value="name">Sort by Name</option>
                    <option value="capacity">Sort by Capacity</option>
                </select>
                
                <button class="filter-btn filter-btn-primary" @onclick="ApplyFilters">
                    <i class="fas fa-filter"></i>
                    <span>Apply Filters</span>
                </button>
                <button class="filter-btn" @onclick="ResetFilters">
                    <i class="fas fa-undo"></i>
                    <span>Reset</span>
                </button>
                
                <button class="filter-btn filter-btn-primary" @onclick="AddNewHall">
                    <i class="fas fa-plus"></i>
                    <span>Add New Hall</span>
                </button>
            </div>
        </div>
        
        <div class="dashboard-card">
            <div class="card-header">
                <h3>All Halls</h3>
                <div class="card-actions">
                    <button class="btn-icon" title="Refresh" @onclick="ApplyFilters">
                        <i class="fas fa-sync-alt"></i>
                    </button>
                </div>
            </div>
            <div class="card-body p-0">
                @if (filteredHalls.Count == 0)
                {
                    <div class="table-empty">
                        <i class="fas fa-film fa-3x"></i>
                        <p>No halls found matching your filters</p>
                        <button class="btn-secondary" @onclick="ResetFilters">Clear Filters</button>
                    </div>
                }
                else
                {
                    <div class="table-container">
                        <table class="admin-table">
                            <thead>
                                <tr>
                                    <th>ID</th>
                                    <th>Name</th>
                                    <th>Capacity</th>
                                    <th>Rows</th>
                                    <th>Seats Per Row</th>
                                    <th>Status</th>
                                    <th>Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var hall in paginatedHalls)
                                {
                                    <tr>
                                        <td>@hall.Id</td>
                                        <td>@hall.Name</td>
                                        <td>@hall.Capacity seats</td>
                                        <td>@hall.Rows</td>
                                        <td>@hall.SeatsPerRow</td>
                                        <td>
                                            <span class="status-badge @(hall.IsActive ? "status-active" : "status-inactive")">
                                                @(hall.IsActive ? "Active" : "Inactive")
                                            </span>
                                        </td>
                                        <td>
                                            <div class="action-buttons">
                                                <button class="btn-text" title="View" @onclick="() => ViewHall(hall)">
                                                    View
                                                </button>
                                                <button class="btn-text" title="Edit" @onclick="() => EditHall(hall)">
                                                   Edit
                                                </button>
                                                <button class="btn-text" title="Delete" @onclick="() => DeleteHall(hall)">
                                                   Delete
                                                </button>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                        
                        <Pagination 
                            CurrentPage="@currentPage"
                            PageSize="@pageSize"
                            TotalItems="@filteredHalls.Count"
                            OnPageChanged="@HandlePageChange"
                            OnPageSizeChanged="@HandlePageSizeChange" />
                    </div>
                }
            </div>
        </div>
        
        @* Add/Edit Hall Modal *@
        @if (showAddEditModal)
        {
            <div class="modal-overlay" @onclick="CloseModal"></div>
            <div class="modal-container modal-md" @onclick:stopPropagation="true">
                <div class="modal-header">
                    <h2 class="modal-title">@(editingHall == null ? "Add New Hall" : "Edit Hall")</h2>
                    <button class="modal-close" @onclick="CloseModal">×</button>
                </div>
                <div class="modal-body">
                    <EditForm Model="@currentHall" OnValidSubmit="SaveHall">
                        <DataAnnotationsValidator />
                        <ValidationSummary class="text-danger mb-3" />
                        
                        <div class="form-group mb-3">
                            <label for="name">Hall Name*</label>
                            <InputText id="name" class="form-control" @bind-Value="currentHall.Name" />
                            <ValidationMessage For="@(() => currentHall.Name)" />
                        </div>
                        
                        <div class="form-group mb-3">
                            <label for="rows">Rows*</label>
                            <InputNumber id="rows" class="form-control" @bind-Value="currentHall.Rows" />
                            <ValidationMessage For="@(() => currentHall.Rows)" />
                        </div>
                        
                        <div class="form-group mb-3">
                            <label for="seatsPerRow">Seats Per Row*</label>
                            <InputNumber id="seatsPerRow" class="form-control" @bind-Value="currentHall.SeatsPerRow" />
                            <ValidationMessage For="@(() => currentHall.SeatsPerRow)" />
                        </div>
                
                        <div class="form-group mb-3">
                            <div class="form-check">
                                <InputCheckbox id="isActive" class="form-check-input" @bind-Value="currentHall.IsActive" />
                                <label class="form-check-label" for="isActive">Active</label>
                            </div>
                        </div>
                    </EditForm>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn-secondary" @onclick="CloseModal">
                        <i class="fas fa-times"></i>
                        Cancel
                    </button>
                    <button type="submit" class="btn-primary" @onclick="SaveHall">
                        <i class="fas fa-save"></i>
                        Save Hall
                    </button>
                </div>
            </div>
        }
        
        @* Delete Confirmation Modal *@
        @if (showDeleteModal && deletingHall != null)
        {
            <div class="modal-overlay" @onclick="CloseModal"></div>
            <div class="modal-container modal-sm" @onclick:stopPropagation="true">
                <div class="modal-header">
                    <h2 class="modal-title">Confirm Delete</h2>
                    <button class="modal-close" @onclick="CloseModal">×</button>
                </div>
                <div class="modal-body">
                    <p>Are you sure you want to delete the hall "<strong>@deletingHall.Name</strong>"?</p>
                    <p class="text-danger">This action cannot be undone.</p>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn-secondary" @onclick="CloseModal">
                        <i class="fas fa-times"></i>
                        Cancel
                    </button>
                    <button type="button" class="btn-danger" @onclick="ConfirmDeleteHall">
                        <i class="fas fa-trash"></i>
                        Delete
                    </button>
                </div>
            </div>
        }
        
        @* View Hall Modal *@
        @if (showViewModal && viewingHall != null)
        {
            <div class="modal-overlay" @onclick="CloseModal"></div>
            <div class="modal-container modal-lg" @onclick:stopPropagation="true">
                <div class="modal-header">
                    <h2 class="modal-title">Hall Details: @viewingHall.Name</h2>
                    <button class="modal-close" @onclick="CloseModal">×</button>
                </div>
                <div class="modal-body">
                    <div class="detail-section">
                        <h4>General Information</h4>
                        <dl class="detail-list">
                            <dt>ID:</dt>
                            <dd>@viewingHall.Id</dd>
                            
                            <dt>Name:</dt>
                            <dd>@viewingHall.Name</dd>
                            
                            <dt>Capacity:</dt>
                            <dd>@viewingHall.Capacity seats</dd>
                            
                            <dt>Rows:</dt>
                            <dd>@viewingHall.Rows</dd>
                            
                            <dt>Seats Per Row:</dt>
                            <dd>@viewingHall.SeatsPerRow</dd>
                            
                            <dt>Status:</dt>
                            <dd>@(viewingHall.IsActive ? "Active" : "Inactive")</dd>
                        </dl>
                    </div>
                    
                    <div class="detail-section">
                        <h4>Seating Layout</h4>
                        <div class="seating-layout">
                            <div class="screen-label">Screen</div>
                            @{
                                char rowLetter = 'A';
                            }
                            @for (int i = 0; i < viewingHall.Rows; i++)
                            {
                                <div class="hall-seat-row">
                                    <span class="row-letter">@rowLetter</span>
                                    @for (int j = 0; j < viewingHall.SeatsPerRow; j++)
                                    {
                                        <div class="hall-seat"></div>
                                    }
                                </div>
                                rowLetter++;
                            }
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn-secondary" @onclick="CloseModal">
                        <i class="fas fa-times"></i>
                        Close
                    </button>
                    <button type="button" class="btn-primary" @onclick="() => EditHall(viewingHall)">
                        <i class="fas fa-edit"></i>
                        Edit
                    </button>
                </div>
            </div>
        }
    }
    
    @if (successMessage != null)
    {
        <div class="alert alert-success">
            <i class="fas fa-check-circle"></i>
            <span>@successMessage</span>
            <button type="button" class="btn-close" @onclick="() => successMessage = null"></button>
        </div>
    }
    
    @if (errorMessage != null)
    {
        <div class="alert alert-danger">
            <i class="fas fa-exclamation-circle"></i>
            <span>@errorMessage</span>
            <button type="button" class="btn-close" @onclick="() => errorMessage = null"></button>
        </div>
    }
</div>

<style>
