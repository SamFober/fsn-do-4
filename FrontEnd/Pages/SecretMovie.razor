@page "/secret-movies"
@using FrontEnd.Models
@implements IDisposable

@inject HttpClient Http
@inject IJSRuntime JS

<PageTitle>Cinemagia - Secret Movies</PageTitle>

<link href="css/home_style.css" rel="stylesheet" />
<link href="css/home_navbar.css" rel="stylesheet" />
<link href="css/seating.css" rel="stylesheet" />
<link href="css/modals.css" rel="stylesheet" />

<div class="cinema-container is-page-home">
    <!-- Gradient Background Wrapper -->
    <div class="gradient-background-wrapper"></div>

    <!-- Navigation Bar -->
    <nav class="homepage-navbar">
        <div class="nav-left-group">
            <div class="logo-container">
                <img src="Cinemagia_logo.jpg" alt="Logo" class="navbar-logo">
            </div>

            <ul class="nav-links @(isMobileMenuOpen ? "active" : "")">
                <li><a href="#film-posters">Movies</a></li>
                <li><a href="/schedule">Schedule</a></li>
                <li><a href="/secret-movies">Secret Movies</a></li>
            </ul>
        </div>

        <!-- Mobile menu icon -->
        <div class="menu-icon" @onclick="ToggleMobileMenu">
            <span></span>
            <span></span>
            <span></span>
        </div>

        <div class="nav-secondary">
            <div class="search-icon">🔍</div>
            <div class="account-icon">👤</div>
            <div class="language-selector">EN</div>
        </div>
    </nav>

    <div class="content-with-header-space">
        <!-- Hero Banner Section -->
        <section class="split-hero">
            <div class="split-hero-content">
                <!-- Movie Logo/Title styled like Pathé -->
                <div class="movie-logo">
                    <h1 class="hero-title">Secret Movies</h1>
                </div>
                <p class="hero-description">Dare to be surprised? Book a secret movie and benefit from a €2.50 discount on all tickets.</p>
                <div class="hero-cta">
                    <a class="hero-btn" @onclick="ScrollToFilmGrid">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="ticket-icon"><path d="M3 7v2a3 3 0 1 1 0 6v2h18v-2a3 3 0 1 1 0-6V7zm0 5h18"></path></svg>
                        Book now
                    </a>
                </div>
            </div>

            <div class="split-angle-divider"></div>

            <div class="split-hero-image">
                <div class="split-hero-backdrop" style="background-image: url('https://images.unsplash.com/photo-1483706600674-e0c87d3fe85b?q=80&w=3907&auto=format&fit=crop&ixlib=rb-4.0.3&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D')"></div>
            </div>
        </section>


        <!-- Secret Movies Section -->
        <section id="film-posters" class="cinema-layout">
            <div class="section-container">
                <h2 class="section-title">Now Showing</h2>

                <div class="film-grid" id="film-grid">
                    @if (Presentations.Count > 0)
                    {
                        @foreach (var presentation in Presentations)
                        {
                            <div class="film-item">
                                <a href="/seat-selector/@presentation.Id" class="film-link">
                                    <div class="poster-wrapper">
                                        <div class="film-poster">
                                            <img src="https://images.unsplash.com/photo-1604975701397-6365ccbd028a?q=80&w=3024&auto=format&fit=crop&ixlib=rb-4.0.3&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D">
                                            <h3>@presentation.Genre</h3>
                                            <h3>@presentation.AgeRating</h3>
                                            <h3>@presentation.StartTime.ToString("dd-MM-yyyy HH:mm")</h3>
                                        </div>
                                    </div>
                                    <h3 class="film-title">Secret Movie</h3>
                                </a>
                                <a href="/seat-selector/@presentation.Id" class="btn-book">Book Now</a>
                            </div>
                        }
                    }
                    else
                    {
                        <div class="text-center loading-container">
                            <h4>No movies available.</h4>
                        </div>
                    }
                </div>
            </div>
        </section>
    </div>
</div>

<style>
    .film-poster {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-direction: column;
    }

    .film-poster img {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    .film-poster h3 {
        position: absolute;
        color: white;
        text-shadow: 2px 2px 8px rgba(0, 0, 0, 0.7);
        font-size: 1.5rem;
        font-weight: bold;
        text-align: center;
        padding: 10px;
    }

    /* Adjust the positioning */
    .film-poster h3:nth-of-type(1) {
        top: 35%; 
    }

    .film-poster h3:nth-of-type(2) {
        top: 45%; 
    }

    .film-poster h3:nth-of-type(3) {
        top: 60%; 
    }
</style>

@code {
    private List<SecretPresentation> Presentations = new();
    private bool isMobileMenuOpen = false;
    private static DotNetObjectReference<SecretMovie>? objRef;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            Presentations = await Http.GetFromJsonAsync<List<SecretPresentation>>("api/presentations/secret") ?? new List<SecretPresentation>();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error fetching secret movies: {ex.Message}");
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            objRef = DotNetObjectReference.Create(this);
            await JS.InvokeVoidAsync("eval", "window.DotNet = DotNet");
            await JS.InvokeVoidAsync("import", "./js/home.js");

            // Add body class for home page
            await JS.InvokeVoidAsync("document.body.classList.add", "is-page-home");
        }
    }

    private void ToggleMobileMenu()
    {
        isMobileMenuOpen = !isMobileMenuOpen;
        StateHasChanged();
    }

    private async Task ScrollToFilmGrid()
    {
        await JS.InvokeVoidAsync("scrollToElement", "film-grid");
    }

    [JSInvokable]
    public static Task CloseMobileMenuSecretMovies()
    {
        if (objRef?.Value != null)
        {
            objRef.Value.isMobileMenuOpen = false;
            objRef.Value.StateHasChanged();
        }
        return Task.CompletedTask;
    }

    public void Dispose()
    {
        objRef?.Dispose();
        // Remove body class when navigating away
        JS.InvokeVoidAsync("document.body.classList.remove", "is-page-home");
    }
}
