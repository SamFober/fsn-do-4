        }
    }

    .overlay-modal-header {
        padding: 20px 25px;
        border-bottom: 1px solid rgba(255, 255, 255, 0.1);
        text-align: center;
    }

        .overlay-modal-header h3 {
            color: white;
            font-weight: bold;
            font-size: 1.8rem;
            margin: 0;
        }

    .overlay-modal-body {
        padding: 40px 25px;
    }

    .overlay-form-container {
        text-align: center;
        max-width: 600px;
        margin: 0 auto;
    }

    .seat-selection-form {
        margin-bottom: 40px;
    }

    .seat-selection-title {
        font-size: 1.6rem;
        margin-bottom: 30px;
        font-weight: 500;
        color: white;
    }

    .seat-counter {
        display: flex;
        justify-content: center;
        align-items: center;
        margin-bottom: 25px;
    }

    .seat-count-input {
        width: 120px;
        height: 80px;
        text-align: center;
        background-color: rgba(255, 255, 255, 0.1);
        border: 1px solid rgba(255, 255, 255, 0.2);
        color: white;
        font-size: 2rem;
        padding: 10px;
        margin: 0 15px;
        border-radius: 8px;
        font-weight: bold;
    }

    .btn-adjust {
        width: 60px;
        height: 60px;
        border-radius: 50%;
        background-color: rgba(255, 255, 255, 0.1);
        border: 1px solid rgba(255, 255, 255, 0.2);
