</style>

@code {
    [Parameter]
    public string orderToken { get; set; } = "";

    public bool isPrintable { get; set; } = false;
    private string? message;
    private bool isMessageFading = false;

    protected override async Task OnInitializedAsync()
    {
        var response = await httpClient.GetAsync($"http://localhost:5213/api/Tickets/{orderToken}/download");

            if (response.IsSuccessStatusCode)
            {
                isPrintable = true;
            }
            else if (response.StatusCode == System.Net.HttpStatusCode.NotFound)
            {
                message = "Error: No tickets found.";
                //alertColor = "color: red;";
            }
            else
            {
                message = "Error: unknown";
                //alertColor = "color: orange;";
            }
    }

    private async Task PrintTickets()
    {
        await JSRuntime.InvokeVoidAsync("openPrintDialog", $"http://localhost:5213/api/Tickets/{orderToken}/download");
    }
}
