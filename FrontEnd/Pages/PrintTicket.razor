        padding-bottom: 15px;
        border-bottom: 1px solid rgba(255, 255, 255, 0.2);
    }

    .price-row {
        display: flex;
        justify-content: space-between;
        margin-bottom: 8px;
        font-size: 1rem;
    }

    .price-total {
        display: flex;
        justify-content: space-between;
        font-weight: bold;
        font-size: 1.2rem;
    }

    .action-buttons {
        display: flex;
        justify-content: space-between;
