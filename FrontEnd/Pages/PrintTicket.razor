    .timer-content {
        display: flex;
        justify-content: center;
        font-size: 0.9rem;
        color: white;
    }

    .countdown {
        font-weight: bold;
        letter-spacing: 1px;
    }

    .cancel-button {
        background: none;
        border: none;
        color: white;
        font-size: 0.9rem;
        cursor: pointer;
        padding: 5px;
        margin-right: 20px;
        font-weight: 500;
        transition: all 0.2s ease;
    }

        .cancel-button:hover {
            color: #f5c518;
        }

    .start-order-btn {
        padding: 12px 30px;
        font-size: 1.2rem;
        border-radius: 8px;
        background-color: #f5c518;
        border-color: #d6aa15;
        color: #000;
        box-shadow: 0 4px 8px rgba(0,0,0,0.2);
        transition: all 0.3s ease;
    }

        .start-order-btn:hover {
            transform: translateY(-3px);
            box-shadow: 0 6px 12px rgba(0,0,0,0.3);
            background-color: #ffcc1d;
        }

    .loading-container {
        background-color: rgba(255, 255, 255, 0.1);
        padding: 30px;
