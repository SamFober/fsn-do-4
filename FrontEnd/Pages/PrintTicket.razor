            height: 24px;
            font-size: 0.6rem;
        }

        .row-label {
            width: 20px;
            font-size: 0.8rem;
        }

        .screen {
            height: 50px;
        }

        .screen-text {
            font-size: 1.2rem;
        }

        .progress-step {
            width: 80px;
        }

            .progress-step:not(:last-child):after {
