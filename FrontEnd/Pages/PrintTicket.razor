        .cinema-alert.fade-out {
            opacity: 0;
            transform: translateY(-10px);
            height: 0;
            margin: 0;
            padding: 0;
            overflow: hidden;
        }

    @@keyframes fadeIn {
        from {
            opacity: 0;
            transform: translateY(-10px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .cinema-alert-success {
        background-color: rgba(40, 167, 69, 0.2);
        border-left: 4px solid #28a745;
        color: #e2e2e2;
    }

    .cinema-alert-danger {
        background-color: rgba(220, 53, 69, 0.2);
        border-left: 4px solid #dc3545;
        color: #e2e2e2;
    }

    .cinema-alert-icon {
        font-size: 1.2rem;
        margin-right: 15px;
        display: flex;
        align-items: center;
        justify-content: center;
        width: 24px;
        height: 24px;
    }

    .cinema-alert-message {
        flex: 1;
        font-weight: 500;
    }

    @@media (max-width: 1000px) {
        .sticky-header-wrapper {
            margin-left: -20px;
            margin-right: -20px;
        }
    }

    .seat-selection-section {
        margin-top: 20px;
    }

    .overlay-modal {
        display: none;
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background-color: rgba(0, 0, 0, 0.8);
        z-index: 2000;
        overflow-y: auto;
        opacity: 0;
        transition: opacity 0.3s ease;
    }

        .overlay-modal.show {
            display: flex;
            opacity: 1;
            align-items: center;
            justify-content: center;
        }

    .overlay-modal-content {
        background-color: #0f1730;
        border-radius: 8px;
        box-shadow: 0 4px 20px rgba(0, 0, 0, 0.5);
        max-width: 950px;
        width: 100%;
        margin: 20px;
        animation: modalFadeIn 0.4s ease-out;
    }

    @@keyframes modalFadeIn {
