@page "/redeem"

@using System.Net.Http
@inject HttpClient Http
@inject IJSRuntime JSRuntime
@using Microsoft.AspNetCore.Components

<PageTitle>Redeem code</PageTitle>

<div class="d-flex justify-content-center align-items-center vh-100">
    <div class="text-center">
        <h3>Redeem Tickets</h3>
        <input @bind="code" class="form-control mb-3" placeholder="Enter your code" />
        <button class="btn custom-button" @onclick="CheckCode">Submit</button>
        @if (!string.IsNullOrEmpty(alertMessage))
        {
            <div class="mt-3">
                <div class="alert" style="@alertColor">@alertMessage</div>
            </div>
        }
    </div>
</div>

<style>
    body {
        background-color: #0f1730;
        color: white;
    }

    .custom-button {
        background-color: #f5c518;
        color: black;
        border: none;
    }

    .custom-button:hover {
        background-color: #e0b315;
    }
</style>

@code {
    private string? code;
    private string? alertMessage;
    private string? alertColor;

    private async Task CheckCode()
    {
        if (string.IsNullOrEmpty(code))
        {
            alertMessage = "Please enter a code.";
            alertColor = "color: red;";
            return;
        }

        try
        {
            var response = await Http.GetAsync($"api/Tickets/phone-booking/{code}/download");

            if (response.IsSuccessStatusCode)
            {
                await JSRuntime.InvokeVoidAsync("openPrintDialog", $"api/Tickets/phone-booking/{code}/download");
                alertMessage = "Here are your tickets! Enjoy!";
                alertColor = "color: green;";
            }
            else if (response.StatusCode == System.Net.HttpStatusCode.NotFound)
            {
                alertMessage = "No tickets found.";
                alertColor = "color: red;";
            }
            else
            {
                alertMessage = "An unexpected error occurred.";
                alertColor = "color: orange;";
            }
        }
        catch (Exception)
        {
            alertMessage = "Failed to contact the server.";
            alertColor = "color: red;";
        }
    }
}