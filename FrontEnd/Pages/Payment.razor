@page "/payment/{orderToken}"
@using FrontEnd.Models.Dtos
@using FrontEnd.Models.Requests

@inject HttpClient Http
@inject NavigationManager Navigation

<h2 class="payment-title">Betaling</h2>

@if (loading)
{
	<div class="loading-container">
		<h4>Even geduld, uw bestelling wordt geladen...</h4>
		<div class="spinner-border" role="status">
			<span class="visually-hidden">Loading...</span>
		</div>
	</div>
}
else if (errorMessage != null)
{
	<div class="alert alert-danger">@errorMessage</div>
}
else if (order != null)
{
	<div>
		<h3>Bestellingsoverzicht</h3>
		<p><strong>Film</strong> @order.MovieTitle</p>
		<p><strong>Stoelen:</strong> @(string.Join(", ", order.Seats))</p>
		<p><strong>Totale prijs:</strong> € @order.TotalAmount.ToString("F2")</p>
	</div>

	<div class="payment-methods">
		<h3>Selecteer betaalmethode</h3>
		<select @bind="selectedPaymentMethod">
			<option value="creditcard">Creditcard</option>
			<option value="paypal">Paypal</option>
			<option value="ideal">iDeal</option>
		</select>
	</div>

	<button @onclick="ProcessPayment" class="pay-button">Betalen</button>
}
else
{
	<div class="alert alert-warning">Geen bestelling gevonden</div>
}

<style>
	.payment-title {
	text-align: center;
	margin-bottom: 20px;
	}

	.order-summary {
	background: #f8f9fa;
	padding: 15px;
	border-radius: 5px;
	}

	.payment-methods {
	margin-top: 20px;
	}

	.pay-button {
	background: green;
	color: white;
	padding: 10px 15px;
	border: none;
	cursor: pointer;
	}
</style>

@code {
	[Parameter]
	public string OrderToken { get; set; }

	private OrderDto? order;
	private string? errorMessage;
	private bool loading = true;
	private string selectedPaymentMethod = "ideal";

	protected override async Task OnInitializedAsync()
	{
		try
		{
			order = await Http.GetFromJsonAsync<OrderDto>($"api/orders/{OrderToken}");
		}
		catch (Exception ex)
		{
			errorMessage = "Fout bij het ophalen van de bestelling.";
		}
		loading = false;
	}

	private async Task ProcessPayment()
	{
		var paymentRequest = new PaymentRequest
			{
				OrderId = order.OrderId,
				Amount = order.TotalAmount,
				Discounts = new List<string>() // Voeg hier kortingen toe indien nodig
			};

		var response = await Http.PostAsJsonAsync("api/payments/process", paymentRequest);

		if (response.IsSuccessStatusCode)
		{
			Navigation.NavigateTo("/confirmation");
		}
		else
		{
			errorMessage = "Betaling mislukt, probeer het opnieuw.";
		}
	}
}