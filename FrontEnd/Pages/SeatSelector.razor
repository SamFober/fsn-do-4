@page "/seat-selector/{presentationId:int}"

@using FrontEnd.Models
@using FrontEnd.Models.Responses
@using Microsoft.JSInterop

@inject HttpClient Http
@inject IJSRuntime JSRuntime

<div class="cinema-container">
    <h3 class="cinema-title">@(presentation?.Title ?? "Unknown Movie") - @(presentation?.HallName ?? "Unknown Hall")</h3>
    
    @if (message != null)
    {
        <div class="alert @(message.Contains("Error") || message.Contains("Failed") ? "alert-danger" : "alert-info")">
            @message
        </div>
    }
    
    @if (!orderStarted)
    {
        @if (presentation?.Rows.Any(r => r.Seats.Any(s => s.IsAvailable)) == true)
        {
            <div class="text-center my-4">
                <button @onclick="ShowOrderModal" class="btn btn-primary btn-lg">Select Seats</button>
            </div>
        }
        else
        {
            <div class="alert alert-info text-center" role="alert">
                <h4 class="alert-heading">Sorry, this showing is fully booked!</h4>
                <p>All seats for this presentation of "@(presentation?.Title)" have been reserved. Please check other showtimes or browse our other exciting movies.</p>
            </div>
        }
    }
    else
    {
        @if (presentation == null)
        {
            <div class="text-center">
                <h4>Loading all seats...</h4>
                <div class="spinner-border" role="status">
                    <span class="visually-hidden">Loading...</span>
                </div>
            </div>
        }
        else
        {
            @if (presentation.Rows.Count > 0)
            {
                <div class="cinema-layout">
                    <div class="seating-container">
                        <div class="seat-map">
                            @foreach (var row in presentation.Rows.OrderBy(r => r.RowNumber))
                            {
                                <div class="seat-row">
                                    <div class="row-label">@row.RowNumber</div>
                                    <div class="seats">
                                        @foreach (var seat in row.Seats.OrderBy(s => s.SeatNumber))
                                        {
                                            var isSelected = selectedSeats.Any(s => s.Id == seat.Id);
                                            string seatClass = isSelected ? "seat-selected" : 
                                                               !seat.IsAvailable ? "seat-unavailable" : "seat-available";
                                            
                                            <div class="seat @seatClass" @onclick="() => SelectSeat(seat)" title="Row @row.RowNumber, Seat @seat.SeatNumber">
                                                <span class="seat-number">@seat.SeatNumber</span>
                                            </div>
                                        }
                                    </div>
                                </div>
                            }
                        </div>
                        <div class="screen">
                            <div class="screen-text">SCREEN</div>
                        </div>
                    </div>
                    
                    <div class="seat-legend">
                        <div class="legend-item">
                            <div class="seat-sample seat-available"></div>
                            <span>Available</span>
                        </div>
                        <div class="legend-item">
                            <div class="seat-sample seat-selected"></div>
                            <span>Selected</span>
                        </div>
                        <div class="legend-item">
                            <div class="seat-sample seat-unavailable"></div>
                            <span>Unavailable</span>
                        </div>
                    </div>
                    
                    @if (selectedSeats.Count > 0)
                    {
                        <div class="order-summary">
                            <h4>Selected Seats:</h4>
                            <ul class="seat-list">
                                @foreach (var seat in selectedSeats.OrderBy(s => s.RowNumber).ThenBy(s => s.SeatNumber))
                                {
                                    <li>Row @seat.RowNumber, Seat @seat.SeatNumber</li>
                                }
                            </ul>
                            <div class="action-buttons">
                                <button @onclick="ConfirmTickets" class="btn btn-success">Confirm Tickets</button>
                                <button @onclick="CancelOrder" class="btn btn-danger">Cancel Order</button>
                            </div>
                        </div>
                    }
                </div>
            }
        }
    }
</div>

<!-- Rename the modal to be more generic -->
<div class="modal fade" id="orderModal" tabindex="-1" aria-labelledby="orderModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="orderModalLabel">Select Number of Seats</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                @if (!string.IsNullOrEmpty(groupOrderError))
                {
                    <div class="alert alert-warning" role="alert">
                        @groupOrderError
                    </div>
                }
                <div class="form-group">
                    <label for="numberOfSeats">How many seats do you need? (Maximum @maxAvailableSeats available)</label>
                    <input type="number" class="form-control" id="numberOfSeats" @bind="numberOfSeats" min="1" max="@maxAvailableSeats" />
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary" @onclick="ProcessOrder">Continue</button>
            </div>
        </div>
    </div>
</div>

<!-- Add this modal for seating options -->
<div class="modal fade" id="seatingOptionsModal" tabindex="-1" aria-labelledby="seatingOptionsModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="seatingOptionsModalLabel">Select Seating Option</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                @if (availableOptions != null)
                {
                    @foreach (var option in availableOptions)
                    {
                        <div class="form-check mb-3">
                            <input class="form-check-input" type="radio" name="seatingOption" 
                                   value="@option.Key" @onchange="@(e => selectedOption = option.Key)" 
                                   checked="@(selectedOption == option.Key)" />
                            <label class="form-check-label">
                                @option.Value.Description
                                <div class="small text-muted">
                                    @foreach (var group in option.Value.Groups)
                                    {
                                        <div>@group.Description</div>
                                    }
                                </div>
                            </label>
                        </div>
                    }
                }
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-danger" @onclick="CancelOrder">Cancel Order</button>
                <button type="button" class="btn btn-primary" @onclick="ConfirmSeatingOption">Confirm Selection</button>
            </div>
        </div>
    </div>
</div>

<!-- Add this modal for single option confirmation -->
<div class="modal fade" id="singleOptionConfirmModal" tabindex="-1" aria-labelledby="singleOptionConfirmModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="singleOptionConfirmModalLabel">Confirm Seating Arrangement</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                @if (singleOptionMessage != null)
                {
                    <p>@singleOptionMessage</p>
                }
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-danger" @onclick="CancelOrder">Cancel Order</button>
                <button type="button" class="btn btn-primary" @onclick="ConfirmSingleOption">Confirm</button>
            </div>
        </div>
    </div>
</div>

<style>
    .cinema-container {
        max-width: 1000px;
        margin: 0 auto;
        padding: 20px;
    }
    
    .cinema-title {
        text-align: center;
        margin-bottom: 20px;
        font-weight: bold;
    }
    
    .cinema-layout {
        display: flex;
        flex-direction: column;
        align-items: center;
        margin-top: 20px;
    }
    
    .seating-container {
        width: 100%;
        max-width: 800px;
        margin-bottom: 30px;
        perspective: 1000px;
    }
    
    .seat-map {
        margin-bottom: 40px;
        transform: rotateX(10deg);
        transform-origin: bottom;
    }
    
    .seat-row {
        display: flex;
        justify-content: center;
        align-items: center;
        margin-bottom: 8px;
    }
    
    .row-label {
        width: 30px;
        text-align: center;
        font-weight: bold;
        color: #888;
    }
    
    .seats {
        display: flex;
        flex-wrap: wrap;
        justify-content: center;
    }
    
    .seat {
        width: 30px;
        height: 28px;
        margin: 3px;
        border-radius: 5px 5px 0 0;
        display: flex;
        justify-content: center;
        align-items: center;
        cursor: pointer;
        position: relative;
        overflow: hidden;
        font-size: 0.75rem;
        color: white;
        text-shadow: 0 0 1px rgba(0,0,0,0.5);
    }
    
    .seat-number {
        position: absolute;
        bottom: 2px;
        font-size: 0.7rem;
    }
    
    .seat-available {
        background-color: #8B8000;
        border: 1px solid #665e00;
        color: white;
    }
    
    .seat-available:hover {
        background-color: #b3a800;
    }
    
    .seat-selected {
        background-color: #28a745;
        border: 1px solid #218838;
    }
    
    .seat-unavailable {
        background-color: #343a40;
        border: 1px solid #1d2124;
        cursor: not-allowed;
        opacity: 0.6;
    }
    
    .screen {
        height: 70px;
        background-color: #151d4a;
        width: 80%;
        margin: 0 auto;
        margin-top: 50px;
        transform: rotateX(-30deg);
        transform-origin: top;
        box-shadow: 0 3px 10px rgba(255, 255, 255, 0.2);
        border-radius: 50%;
        display: flex;
        justify-content: center;
        align-items: center;
    }
    
    .screen-text {
        color: rgba(255, 255, 255, 0.7);
        font-size: 1.5rem;
        letter-spacing: 3px;
    }
    
    .seat-legend {
        display: flex;
        justify-content: center;
        margin: 30px 0;
    }
    
    .legend-item {
        display: flex;
        align-items: center;
        margin: 0 15px;
    }
    
    .seat-sample {
        width: 24px;
        height: 24px;
        border-radius: 5px 5px 0 0;
        margin-right: 8px;
    }
    
    .order-summary {
        margin-top: 20px;
        border: 1px solid #ddd;
        border-radius: 5px;
        padding: 20px;
        width: 100%;
        max-width: 500px;
    }
    
    .seat-list {
        list-style-type: none;
        padding: 0;
        margin-bottom: 20px;
    }
    
    .seat-list li {
        display: inline-block;
        margin-right: 10px;
        margin-bottom: 5px;
        background-color: #f8f9fa;
        padding: 5px 10px;
        border-radius: 3px;
    }
    
    .action-buttons {
        display: flex;
        justify-content: space-between;
    }
</style>

@code {
    [Parameter]
    public int PresentationId { get; set; }

    private Presentation? presentation;
    private string? message;
    private bool orderStarted = false;
    private int numberOfSeats = 1;
    private List<Seat> selectedSeats = new List<Seat>();
    private string? orderToken;
    private int? preselectedSeatId;
    private Dictionary<string, SeatingOption>? availableOptions;
    private string? selectedOption;
    private string? singleOptionMessage;
    private GroupOrderResponse? pendingGroupOrder;
    private string? groupOrderError;
    private int maxAvailableSeats;

    protected override async Task OnInitializedAsync()
    {

        try
        {
            presentation = await Http.GetFromJsonAsync<Presentation>($"api/presentations/{PresentationId}/seats");

            if (presentation == null || presentation.Rows.Count == 0)
            {
                message = "No seats available for this presentation.";
            }
        }
        catch (Exception ex)
        {
            message = $"Error fetching seats: {ex.Message}";
        }
    }

    private async Task ShowOrderModal()
    {
        // Clear any previous error message
        groupOrderError = null;

        // Calculate maximum available seats
        maxAvailableSeats = presentation?.Rows
            .SelectMany(r => r.Seats)
            .Count(s => s.IsAvailable) ?? 0;

        // Ensure numberOfSeats doesn't exceed maxAvailableSeats
        if (numberOfSeats > maxAvailableSeats)
        {
            numberOfSeats = maxAvailableSeats;
        }

        // Default to 1 seat if not set
        if (numberOfSeats < 1)
        {
            numberOfSeats = 1;
        }

        await JSRuntime.InvokeVoidAsync("showModal", "orderModal");
    }

    private async Task ProcessOrder()
    {
        // Check if the user selected a valid number of seats
        if (numberOfSeats <= 0 || numberOfSeats > maxAvailableSeats)
        {
            groupOrderError = $"Please select between 1 and {maxAvailableSeats} seats.";
            return;
        }

        // Hide the modal
        await JSRuntime.InvokeVoidAsync("hideModal", "orderModal");

        // Start single or group order based on the number of seats
        if (numberOfSeats == 1)
        {
            await StartOrder();
        }
        else
        {
            await StartGroupOrder();
        }
    }

    private async Task StartOrder()
    {
        Console.WriteLine("StartOrder called");
        try
        {
            var response = await Http.PostAsJsonAsync("api/tickets/orders/start", new { presentationId = PresentationId });
            if (response.IsSuccessStatusCode)
            {
                var result = await response.Content.ReadFromJsonAsync<OrderResponse>();
                orderToken = result.OrderToken;
                orderStarted = true;
                
                // Handle pre-selected seats from the SeatIds array
                if (result.SeatIds != null && result.SeatIds.Any())
                {
                    var preselectedSeats = presentation.Rows
                        .SelectMany(r => r.Seats)
                        .Where(s => result.SeatIds.Contains(s.Id))
                        .ToList();
                    
                    if (preselectedSeats.Any())
                    {
                        selectedSeats.Clear();
                        selectedSeats.AddRange(preselectedSeats);
                        
                        if (preselectedSeats.Count == 1)
                        {
                            var seat = preselectedSeats.First();
                            message = $"Order started with pre-selected seat Row {seat.RowNumber}, Seat {seat.SeatNumber}.";
                        }
                        else
                        {
                            message = $"Order started with {preselectedSeats.Count} pre-selected seats.";
                        }
                        
                        Console.WriteLine($"Preselected seats added: {string.Join(", ", preselectedSeats.Select(s => s.SeatNumber))}");
                    }
                    else
                    {
                        message = "Order started. Please select your seats.";
                    }
                }
                else 
                {
                    message = "Order started. Please select your seats.";
                }
                
                Console.WriteLine($"Order started successfully. Order Token: {orderToken}");

                // Load all seats immediately after starting the order
                await LoadSeats();
            }
            else
            {
                var errorMessage = await response.Content.ReadAsStringAsync();
                message = $"Failed to start order: {errorMessage}";
                Console.WriteLine(message);
            }
        }
        catch (Exception ex)
        {
            message = $"Error starting order: {ex.Message}";
            Console.WriteLine(message);
        }
    }

    private async Task StartGroupOrder()
    {
        Console.WriteLine($"StartGroupOrder called with {numberOfSeats} seats");
        try
        {
            // Clear any previous error message
            groupOrderError = null;

            // First check how many seats are actually available
            var availableSeats = presentation?.Rows
                .SelectMany(r => r.Seats)
                .Where(s => s.IsAvailable)
                .ToList() ?? new List<Seat>();

            var availableSeatsCount = availableSeats.Count;
            Console.WriteLine($"Available seats: {availableSeatsCount}");

            if (availableSeatsCount == 0)
            {
                groupOrderError = "No seats are available for this presentation.";
                return;
            }

            if (numberOfSeats > availableSeatsCount)
            {
                groupOrderError = $"Only {availableSeatsCount} seats are available. You requested {numberOfSeats} seats.";
                return;
            }

            if (numberOfSeats <= 0 || numberOfSeats > 20)
            {
                groupOrderError = "Please select between 1 and 20 seats.";
                return;
            }

            // Hide the modal only if there are no errors
            await JSRuntime.InvokeVoidAsync("hideModal", "orderModal");

            // Call the API to start a group order with the specified number of seats
            var response = await Http.PostAsJsonAsync("api/tickets/orders/start-group", new { presentationId = PresentationId, numberOfSeats });
            if (response.IsSuccessStatusCode)
            {
                var result = await response.Content.ReadFromJsonAsync<GroupOrderResponse>();
                pendingGroupOrder = result;
                availableOptions = result.AvailableOptions;

                if (availableOptions != null)
                {
                    if (availableOptions.Count > 1)
                    {
                        // Show the options modal for multiple options
                        selectedOption = availableOptions.Keys.First();
                        await JSRuntime.InvokeVoidAsync("showModal", "seatingOptionsModal");
                    }
                    else if (availableOptions.Count == 1)
                    {
                        // Handle single option case
                        var option = availableOptions.First();
                        selectedOption = option.Key;

                        if (option.Key != "consecutive")
                        {
                            // Show confirmation modal for split or smaller consecutive
                            singleOptionMessage = option.Key == "split" 
                                ? "The only available option is to split your group. Would you like to proceed with split seating?"
                                : $"We can offer {numberOfSeats - 1} consecutive seats. Would you like to proceed with fewer seats?";
                            
                            await JSRuntime.InvokeVoidAsync("showModal", "singleOptionConfirmModal");
                        }
                        else
                        {
                            // Automatically confirm consecutive seating
                            await SelectSeatingOption(option.Key);
                        }
                    }
                }
            }
            else
            {
                var errorMessage = await response.Content.ReadAsStringAsync();
                message = $"Failed to start group order: {errorMessage}";
                Console.WriteLine(message);
            }
        }
        catch (Exception ex)
        {
            message = $"Error starting group order: {ex.Message}";
            Console.WriteLine(message);
        }
    }

    private async Task LoadSeats()
    {
        try
        {
            // Store the IDs of seats that were previously selected
            var selectedSeatIds = selectedSeats.Select(s => s.Id).ToList();
            
            // Fetch updated seat information
            presentation = await Http.GetFromJsonAsync<Presentation>($"api/presentations/{PresentationId}/seats");
            
            if (presentation == null || presentation.Rows.Count == 0)
            {
                message = "No seats available for this presentation.";
                return;
            }
            
            // Clear and rebuild the selectedSeats list with the updated seat objects
            selectedSeats.Clear();
            
            // For each previously selected seat ID, find the seat in the refreshed data
            foreach (var seatId in selectedSeatIds)
            {
                var updatedSeat = presentation.Rows
                    .SelectMany(r => r.Seats)
                    .FirstOrDefault(s => s.Id == seatId);
                
                if (updatedSeat != null)
                {
                    selectedSeats.Add(updatedSeat);
                }
            }
        }
        catch (Exception ex)
        {
            message = $"Error fetching seats: {ex.Message}";
        }
    }

    private async Task SelectSeat(Seat seat)
    {
        Console.WriteLine($"SelectSeat called for seat {seat.SeatNumber}");

        // Check if the seat is already in our selectedSeats list
        var existingSeat = selectedSeats.FirstOrDefault(s => s.Id == seat.Id);
        bool isSelected = existingSeat != null;

        if (isSelected)
        {
            // Check if this is the last selected seat
            if (selectedSeats.Count == 1)
            {
                message = "Warning: At least one seat must be selected.";
                Console.WriteLine("Attempted to deselect the last seat - operation prevented");
                return;
            }

            // If the seat is already selected, remove it from the list
            selectedSeats.Remove(existingSeat);
            Console.WriteLine($"Seat {seat.SeatNumber} unselected.");

            // Call the DELETE API to remove the seat from the order
            if (!string.IsNullOrEmpty(orderToken))
            {
                var response = await Http.DeleteAsync($"api/tickets/orders/{orderToken}/seats/{seat.Id}");

                if (response.IsSuccessStatusCode)
                {
                    message = $"Seat {seat.SeatNumber} removed from the order.";
                    Console.WriteLine(message);
                }
                else
                {
                    var errorMessage = await response.Content.ReadAsStringAsync();
                    message = $"Failed to remove seat {seat.SeatNumber} from the order: {errorMessage}";
                    Console.WriteLine(message);
                }
            }
        }
        else
        {
            // If the seat is not selected and is available, add it
            if (seat.IsAvailable)
            {
                // Add the seat to our selected list
                selectedSeats.Add(seat);
                Console.WriteLine($"Seat {seat.SeatNumber} selected.");

                // Call the API to add the seat to the order
                if (!string.IsNullOrEmpty(orderToken))
                {
                    var response = await Http.PostAsJsonAsync($"api/tickets/orders/{orderToken}/seats", new { seatIds = new List<int> { seat.Id } });

                    if (response.IsSuccessStatusCode)
                    {
                        var result = await response.Content.ReadFromJsonAsync<OrderResponse>();
                        orderToken = result.OrderToken; // Store the order token for confirmation
                        message = "Seat selected successfully!";
                        Console.WriteLine("Seat selected successfully.");
                    }
                    else
                    {
                        var errorMessage = await response.Content.ReadAsStringAsync();
                        message = $"Failed to select seat: {errorMessage}";
                        Console.WriteLine(message);
                    }
                }
            }
            else
            {
                message = "This seat is not available for selection.";
                Console.WriteLine(message);
            }
        }

        // Refetch the seats to get the latest availability
        await LoadSeats();

        // Update the UI
        StateHasChanged();
    }

    private async Task ConfirmTickets()
    {
        var confirmationResponse = await Http.PostAsJsonAsync($"api/tickets/orders/{orderToken}/confirm", new { customerName = "NamHere", customerEmail = "validEmailHere" });

        if (confirmationResponse.IsSuccessStatusCode)
        {
            message = "Tickets confirmed successfully!";
        }
        else
        {
            var errorMessage = await confirmationResponse.Content.ReadAsStringAsync();
            message = $"Failed to confirm tickets: {errorMessage}";
        }
    }

    private async Task ConfirmSeatingOption()
    {
        if (selectedOption != null)
        {
            await JSRuntime.InvokeVoidAsync("hideModal", "seatingOptionsModal");
            await SelectSeatingOption(selectedOption);
        }
    }

    private async Task ConfirmSingleOption()
    {
        if (selectedOption != null)
        {
            await JSRuntime.InvokeVoidAsync("hideModal", "singleOptionConfirmModal");
            await SelectSeatingOption(selectedOption);
        }
    }

    private async Task SelectSeatingOption(string option)
    {
        try
        {
            if (pendingGroupOrder?.OrderToken == null)
            {
                message = "No pending group order found.";
                return;
            }

            var request = new { OrderToken = pendingGroupOrder.OrderToken };
            var response = await Http.PostAsJsonAsync($"api/tickets/orders/select-option/{option}", request);

            if (response.IsSuccessStatusCode)
            {
                var result = await response.Content.ReadFromJsonAsync<OrderResponse>();
                orderToken = result.OrderToken;
                orderStarted = true;

                // Now we can add the selected seats
                if (result.SeatIds != null && result.SeatIds.Any())
                {
                    var selectedSeatsFromResponse = presentation.Rows
                        .SelectMany(r => r.Seats)
                        .Where(s => result.SeatIds.Contains(s.Id))
                        .ToList();

                    selectedSeats.Clear();
                    selectedSeats.AddRange(selectedSeatsFromResponse);
                    message = $"Group order started with {selectedSeats.Count} seats selected.";
                }

                // Load all seats to refresh the UI
                await LoadSeats();
            }
            else
            {
                var errorMessage = await response.Content.ReadAsStringAsync();
                message = $"Failed to select seating option: {errorMessage}";
            }
        }
        catch (Exception ex)
        {
            message = $"Error selecting seating option: {ex.Message}";
            Console.WriteLine(message);
        }
    }

    private async Task CancelOrder()
    {
        try
        {
            string? tokenToCancel = orderToken ?? pendingGroupOrder?.OrderToken;
            if (tokenToCancel != null)
            {
                // Hide any open modals first
                await JSRuntime.InvokeVoidAsync("hideModal", "seatingOptionsModal");
                await JSRuntime.InvokeVoidAsync("hideModal", "singleOptionConfirmModal");
                await JSRuntime.InvokeVoidAsync("hideModal", "orderModal");

                // Call the API to cancel the order
                var response = await Http.PostAsync($"api/tickets/orders/{tokenToCancel}/cancel", null);
                
                if (response.IsSuccessStatusCode)
                {
                    // Clear local state
                    orderToken = null;
                    pendingGroupOrder = null;
                    selectedSeats.Clear();
                    orderStarted = false;
                    availableOptions = null;
                    selectedOption = null;
                    message = "Order cancelled successfully.";

                    // Refresh the seats to show updated availability
                    await LoadSeats();
                }
                else
                {
                    var error = await response.Content.ReadAsStringAsync();
                    message = $"Failed to cancel order: {error}";
                }
            }
        }
        catch (Exception ex)
        {
            message = $"Error cancelling order: {ex.Message}";
            Console.WriteLine($"Error cancelling order: {ex}");
        }
    }
} 