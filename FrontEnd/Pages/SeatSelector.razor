    private void NumpadAddNumber(string number)
    {
        if (numpadInputValue == "Invalid PIN") NumpadClearInput();
        if (numpadInputValue.Length < 4)
    numpadInputValue += number;
    }

    private void NumpadRemoveNumber()
    {
        if (!string.IsNullOrEmpty(numpadInputValue) && numpadInputValue != "Error" && numpadInputValue != "Confirmed")
        {
    numpadInputValue = numpadInputValue[..^1];
        }
    }

    private void NumpadClearInput() => numpadInputValue = "";

    public async Task NumpadConfirmInput()
    {
        var validCodes = new List<string> { "1234", "5678", "9876" };
        
        if (validCodes.Contains(numpadInputValue))
        {
            numpadInputValue = "Processing..";
            await Task.Delay(2000);
            numpadInputValue = "Confirmed";
            numpadPinConfirmed = true;
        } else
        {
            numpadInputValue = "Invalid PIN";
        }
    }

