@code {
    [Parameter]
    public int PresentationId { get; set; }

    private Presentation? presentation;
    private string? message;
    private int numberOfSeats = 1;
    private List<Seat> selectedSeats = new List<Seat>();
    private string? orderToken;
    private int? preselectedSeatId;
    private Dictionary<string, SeatingOption>? availableOptions;
    private string? selectedOption;
    private string? singleOptionMessage;
    private GroupOrderResponse? pendingGroupOrder;
    private string? groupOrderError;
    private int maxAvailableSeats;
    
    // Timer properties
    private DateTime? orderExpirationTime;
    private Timer expirationTimer = new Timer(1000);
    private Timer validationTimer = new Timer(30000);
    private TimeSpan timeRemaining = TimeSpan.Zero;
    
    private Dictionary<int, string> ticketTypes = new Dictionary<int, string>();
    private int activeStep = 1;
    
    private Timer messageTimer = new Timer(5000); // 5 seconds
    private bool isMessageFading = false;
    private Timer fadeTimer = new Timer(400); // For the fade out transition
    
    // Static instance management for JS Interop
    private static SeatSelector _instance;
    
    // Modal visibility control
    private bool showSeatSelectionModal = true;
    
    protected override void OnInitialized()
    {
        _instance = this;
        expirationTimer.Elapsed += TimerTick;
        validationTimer.Elapsed += ValidateOrderWithBackend;
        messageTimer.AutoReset = false;
        messageTimer.Elapsed += StartMessageFadeOut;
        fadeTimer.AutoReset = false; 
        fadeTimer.Elapsed += CompleteMessageFadeOut;
    }
    
    private void StartMessageFadeOut(object? sender, ElapsedEventArgs e)
    {
        InvokeAsync(() => 
        {
            isMessageFading = true;
            StateHasChanged();
            fadeTimer.Start();
        });
    }
    
    private void CompleteMessageFadeOut(object? sender, ElapsedEventArgs e)
    {
        InvokeAsync(() => 
        {
            message = null;
            isMessageFading = false;
            StateHasChanged();
        });
    }
    
    private void SetMessage(string newMessage)
    {
        // Stop any existing fade process
        fadeTimer.Stop();
        messageTimer.Stop();
        
        // Reset message state
        isMessageFading = false;
        message = newMessage;
        
        // Start the message timer
        messageTimer.Start();
    }
    
    private void TimerTick(object? sender, ElapsedEventArgs e)
    {
        if (orderExpirationTime.HasValue)
        {
            timeRemaining = orderExpirationTime.Value - DateTime.UtcNow;
            if (timeRemaining.TotalSeconds <= 0)
            {
                expirationTimer.Stop();
                validationTimer.Stop();
                
                // Order has expired, reset the state
                InvokeAsync(async () => 
                {
                    // Call the backend to ensure the order is marked as expired there too
                    await ExpireOrder();
                    
                    SetMessage("Your order has expired. Please start a new order.");
                    orderExpirationTime = null;
                    orderToken = null;
                    pendingGroupOrder = null;
                    selectedSeats.Clear();
                    
                    // Refresh the seats to show updated availability
                    await LoadSeats();
                    
                    StateHasChanged();
                });
            }
            else
            {
                InvokeAsync(StateHasChanged);
            }
        }
    }
    
    private async void ValidateOrderWithBackend(object? sender, ElapsedEventArgs e)
    {
        if (string.IsNullOrEmpty(orderToken) && pendingGroupOrder?.OrderToken == null)
        {
            return; // No active order to validate
        }
        
        try
        {
            string currentToken = orderToken ?? pendingGroupOrder?.OrderToken?.ToString() ?? string.Empty;
            
            if (string.IsNullOrEmpty(currentToken))
            {
                return;
            }
            
            // Call the API to check if the order is still valid
            var response = await Http.GetAsync($"api/tickets/orders/{currentToken}/check");
            
            if (!response.IsSuccessStatusCode)
            {
                // Order is no longer valid, reset the state
                await InvokeAsync(async () => 
                {
                    expirationTimer.Stop();
                    validationTimer.Stop();
                    
                    SetMessage("Your order has expired or is no longer valid. Please start a new order.");
                    orderExpirationTime = null;
                    orderToken = null;
                    pendingGroupOrder = null;
                    selectedSeats.Clear();
                    
                    // Refresh the seats to show updated availability
                    await LoadSeats();
                    
                    StateHasChanged();
                });
            }
            else
            {
                // Order is still valid, potentially update expiration time based on response
                var result = await response.Content.ReadFromJsonAsync<OrderStatusResponse>();
                
                if (result != null && result.ExpiresAt.HasValue)
                {
                    await InvokeAsync(() => 
                    {
                        // Update our local expiration time to match the server
                        orderExpirationTime = result.ExpiresAt.Value;
                        timeRemaining = orderExpirationTime.Value - DateTime.UtcNow;
                        StateHasChanged();
                    });
                }
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error validating order: {ex.Message}");
            // Don't invalidate the order on connection errors
        }
    }
    
    private async Task ExpireOrder()
    {
        string? tokenToExpire = orderToken ?? pendingGroupOrder?.OrderToken;
        if (tokenToExpire != null)
        {
            try
            {
                // Just notify the backend that the order is expired from client side
                await Http.PostAsync($"api/tickets/orders/{tokenToExpire}/expire", null);
            }
            catch (Exception ex)
            {
                Console.WriteLine($"Error expiring order: {ex.Message}");
                // Continue with local expiration even if server call fails
            }
        }
    }
    
    public void Dispose()
    {
        expirationTimer.Elapsed -= TimerTick;
        validationTimer.Elapsed -= ValidateOrderWithBackend;
        messageTimer.Elapsed -= StartMessageFadeOut;
        fadeTimer.Elapsed -= CompleteMessageFadeOut;
        expirationTimer.Dispose();
        validationTimer.Dispose();
        messageTimer.Dispose();
        fadeTimer.Dispose();
        if (_instance == this)
        {
            _instance = null;
        }
    }

    protected override async Task OnInitializedAsync()
    {
        try
        {
            presentation = await Http.GetFromJsonAsync<Presentation>($"api/presentations/{PresentationId}/seats");

            if (presentation == null || presentation.Rows.Count == 0)
            {
                SetMessage("No seats available for this presentation.");
            }
            else
            {
                // Calculate maximum available seats
                maxAvailableSeats = presentation.Rows
                    .SelectMany(r => r.Seats)
                    .Count(s => s.IsAvailable);
                
                // Set a default value for numberOfSeats
                numberOfSeats = Math.Min(2, maxAvailableSeats);

                // If no seats are available, show a message
                if (maxAvailableSeats == 0)
                {
                    SetMessage("Sorry, this showing is fully booked! Please check other showtimes.");
                    showSeatSelectionModal = false;
                }
                else
                {
                    // Initialize the modal
                    showSeatSelectionModal = true;
                    groupOrderError = null;
                }
            }
        }
        catch (Exception ex)
        {
            SetMessage($"Error fetching seats: {ex.Message}");
        }
    }

    private void IncrementSeats()
    {
        if (numberOfSeats < maxAvailableSeats)
        {
            numberOfSeats++;
        }
    }
    
    private void DecrementSeats()
    {
        if (numberOfSeats > 1)
        {
            numberOfSeats--;
        }
    }
    
    private async Task ProcessOrder()
    {
        // Check if the user selected a valid number of seats
        if (numberOfSeats <= 0 || numberOfSeats > maxAvailableSeats)
        {
            groupOrderError = $"Please select between 1 and {maxAvailableSeats} seats.";
            return;
        }

        // Hide the modal only
        showSeatSelectionModal = false;

        // Start single or group order based on the number of seats
        if (numberOfSeats == 1)
        {
            await StartOrder();
        }
        else
        {
            await StartGroupOrder();
        }
    }

    private async Task StartOrder()
    {
        Console.WriteLine("StartOrder called");
        try
        {
            // Hide the modal during the API call
            showSeatSelectionModal = false;
            
            var response = await Http.PostAsJsonAsync("api/tickets/orders/start", new { presentationId = PresentationId });
            if (response.IsSuccessStatusCode)
            {
                var result = await response.Content.ReadFromJsonAsync<OrderResponse>();
                orderToken = result.OrderToken;
                
                // Set the expiration time (10 minutes from now)
                orderExpirationTime = DateTime.UtcNow.AddMinutes(10);
                timeRemaining = TimeSpan.FromMinutes(10);
                expirationTimer.Start();
                validationTimer.Start();
                
                // Handle pre-selected seats from the SeatIds array
                if (result.SeatIds != null && result.SeatIds.Any())
                {
                    var preselectedSeats = presentation.Rows
                        .SelectMany(r => r.Seats)
                        .Where(s => result.SeatIds.Contains(s.Id))
                        .ToList();
                    
                    if (preselectedSeats.Any())
                    {
                        selectedSeats.Clear();
                        selectedSeats.AddRange(preselectedSeats);
                        
                        if (preselectedSeats.Count == 1)
                        {
                            var seat = preselectedSeats.First();
                            SetMessage($"Order started with pre-selected seat Row {seat.RowNumber}, Seat {seat.SeatNumber}.");
                        }
                        else
                        {
                            SetMessage($"Order started with {preselectedSeats.Count} pre-selected seats.");
                        }
                        
                        Console.WriteLine($"Preselected seats added: {string.Join(", ", preselectedSeats.Select(s => s.SeatNumber))}");
                    }
                    else
                    {
                        SetMessage("Order started. Please select your seats.");
                    }
                }
                else 
                {
                    SetMessage("Order started. Please select your seats.");
                }
                
                Console.WriteLine($"Order started successfully. Order Token: {orderToken}");

                // Load all seats immediately after starting the order
                await LoadSeats();
            }
            else
            {
                var errorMessage = await response.Content.ReadAsStringAsync();
                SetMessage($"Failed to start order: {errorMessage}");
                Console.WriteLine($"Failed to start order: {errorMessage}");
                
                // Show the modal again if there was an error
                showSeatSelectionModal = true;
            }
        }
        catch (Exception ex)
        {
            SetMessage($"Error starting order: {ex.Message}");
            Console.WriteLine($"Error starting order: {ex.Message}");
            
            // Show the modal again if there was an error
            showSeatSelectionModal = true;
        }
    }

    private async Task StartGroupOrder()
    {
        Console.WriteLine($"StartGroupOrder called with {numberOfSeats} seats");
        try
        {
            // Clear any previous error message
            groupOrderError = null;

            // First check how many seats are actually available
            var availableSeats = presentation?.Rows
                .SelectMany(r => r.Seats)
                .Where(s => s.IsAvailable)
                .ToList() ?? new List<Seat>();

            var availableSeatsCount = availableSeats.Count;
            Console.WriteLine($"Available seats: {availableSeatsCount}");

            if (availableSeatsCount == 0)
            {
                groupOrderError = "No seats are available for this presentation.";
                showSeatSelectionModal = true;
                return;
            }

            if (numberOfSeats > availableSeatsCount)
            {
                groupOrderError = $"Only {availableSeatsCount} seats are available. You requested {numberOfSeats} seats.";
                showSeatSelectionModal = true;
                return;
            }

            if (numberOfSeats <= 0 || numberOfSeats > 20)
            {
                groupOrderError = "Please select between 1 and 20 seats.";
                showSeatSelectionModal = true;
                return;
            }

            // Call the API to start a group order with the specified number of seats
            var response = await Http.PostAsJsonAsync("api/tickets/orders/start-group", new { presentationId = PresentationId, numberOfSeats });
            if (response.IsSuccessStatusCode)
            {
                var result = await response.Content.ReadFromJsonAsync<GroupOrderResponse>();
                pendingGroupOrder = result;
                availableOptions = result.AvailableOptions;
                
                // Set the expiration time (10 minutes from now)
                orderExpirationTime = DateTime.UtcNow.AddMinutes(10);
                timeRemaining = TimeSpan.FromMinutes(10);
                expirationTimer.Start();
                validationTimer.Start();

                if (availableOptions != null)
                {
                    if (availableOptions.Count > 1)
                    {
                        // Show the options modal for multiple options
                        selectedOption = availableOptions.Keys.First();
                        await JSRuntime.InvokeVoidAsync("showModal", "seatingOptionsModal");
                    }
                    else if (availableOptions.Count == 1)
                    {
                        // Handle single option case
                        var option = availableOptions.First();
                        selectedOption = option.Key;

                        if (option.Key != "consecutive")
                        {
                            // Show confirmation modal for split or smaller consecutive
                            singleOptionMessage = option.Key == "split" 
                                ? "The only available option is to split your group. Would you like to proceed with split seating?"
                                : $"We can offer {numberOfSeats - 1} consecutive seats. Would you like to proceed with fewer seats?";
                            
                            await JSRuntime.InvokeVoidAsync("showModal", "singleOptionConfirmModal");
                        }
                        else
                        {
                            // Automatically confirm consecutive seating
                            await SelectSeatingOption(option.Key);
                        }
                    }
                }
            }
            else
            {
                var errorMessage = await response.Content.ReadAsStringAsync();
                SetMessage($"Failed to start group order: {errorMessage}");
                Console.WriteLine($"Failed to start group order: {errorMessage}");
                
                // Show the modal again if there was an error
                showSeatSelectionModal = true;
            }
        }
        catch (Exception ex)
        {
            SetMessage($"Error starting group order: {ex.Message}");
            Console.WriteLine($"Error starting group order: {ex.Message}");
            
            // Show the modal again if there was an error
            showSeatSelectionModal = true;
        }
    }

    private async Task LoadSeats()
    {
        try
        {
            // Store the IDs of seats that were previously selected
            var selectedSeatIds = selectedSeats.Select(s => s.Id).ToList();
            
            // Fetch updated seat information
            presentation = await Http.GetFromJsonAsync<Presentation>($"api/presentations/{PresentationId}/seats");
            
            if (presentation == null || presentation.Rows.Count == 0)
            {
                SetMessage("No seats available for this presentation.");
                return;
            }
            
            // Clear and rebuild the selectedSeats list with the updated seat objects
            selectedSeats.Clear();
            
            // For each previously selected seat ID, find the seat in the refreshed data
            foreach (var seatId in selectedSeatIds)
            {
                var updatedSeat = presentation.Rows
                    .SelectMany(r => r.Seats)
                    .FirstOrDefault(s => s.Id == seatId);
                
                if (updatedSeat != null)
                {
                    selectedSeats.Add(updatedSeat);
                }
            }
        }
        catch (Exception ex)
        {
            SetMessage($"Error fetching seats: {ex.Message}");
        }
    }

    private async Task SelectSeat(Seat seat)
    {
        Console.WriteLine($"SelectSeat called for seat {seat.SeatNumber}");

        // Check if the seat is already in our selectedSeats list
        var existingSeat = selectedSeats.FirstOrDefault(s => s.Id == seat.Id);
        bool isSelected = existingSeat != null;

        if (isSelected)
        {
            // Check if this is the last selected seat
            if (selectedSeats.Count == 1)
            {
                SetMessage("Warning: At least one seat must be selected.");
                Console.WriteLine("Attempted to deselect the last seat - operation prevented");
                return;
            }

            // If the seat is already selected, remove it from the list
            selectedSeats.Remove(existingSeat);
            Console.WriteLine($"Seat {seat.SeatNumber} unselected.");

            // Remove the ticket type for this seat
            if (ticketTypes.ContainsKey(seat.Id))
            {
                ticketTypes.Remove(seat.Id);
            }

            // Call the DELETE API to remove the seat from the order
            if (!string.IsNullOrEmpty(orderToken))
            {
                var response = await Http.DeleteAsync($"api/tickets/orders/{orderToken}/seats/{seat.Id}");

                if (response.IsSuccessStatusCode)
                {
                    SetMessage($"Seat {seat.SeatNumber} removed from the order.");
                    Console.WriteLine($"Seat {seat.SeatNumber} removed from the order.");
                }
                else
                {
                    var errorMessage = await response.Content.ReadAsStringAsync();
                    SetMessage($"Failed to remove seat {seat.SeatNumber} from the order: {errorMessage}");
                    Console.WriteLine($"Failed to remove seat {seat.SeatNumber} from the order: {errorMessage}");
                }
            }
        }
        else
        {
            // If the seat is not selected and is available, add it
            if (seat.IsAvailable)
            {
                // Add the seat to our selected list
                selectedSeats.Add(seat);
                Console.WriteLine($"Seat {seat.SeatNumber} selected.");

                // Call the API to add the seat to the order
                if (!string.IsNullOrEmpty(orderToken))
                {
                    var response = await Http.PostAsJsonAsync($"api/tickets/orders/{orderToken}/seats", new { seatIds = new List<int> { seat.Id } });

                    if (response.IsSuccessStatusCode)
                    {
                        var result = await response.Content.ReadFromJsonAsync<OrderResponse>();
                        orderToken = result.OrderToken; // Store the order token for confirmation
                        SetMessage("Seat selected successfully!");
                        Console.WriteLine("Seat selected successfully.");
                    }
                    else
                    {
                        var errorMessage = await response.Content.ReadAsStringAsync();
                        SetMessage($"Failed to select seat: {errorMessage}");
                        Console.WriteLine($"Failed to select seat: {errorMessage}");
                    }
                }
            }
            else
            {
                SetMessage("This seat is not available for selection.");
                Console.WriteLine("This seat is not available for selection.");
            }
        }

        // Refetch the seats to get the latest availability
        await LoadSeats();

        // Update the UI
        StateHasChanged();
    }

    private async Task ConfirmTickets()
    {
        try {
            // Stop both timers when tickets are confirmed
            expirationTimer.Stop();
            validationTimer.Stop();
            orderExpirationTime = null;
            
            var confirmationResponse = await Http.PostAsJsonAsync($"api/tickets/orders/{orderToken}/confirm", new { customerName = "NamHere", customerEmail = "validEmailHere" });

            if (confirmationResponse.IsSuccessStatusCode)
            {
                SetMessage("Tickets confirmed successfully!");
            }
            else
            {
                var errorMessage = await confirmationResponse.Content.ReadAsStringAsync();
                SetMessage($"Failed to confirm tickets: {errorMessage}");
            }
        }
        catch (Exception ex)
        {
            SetMessage($"Error confirming tickets: {ex.Message}");
            Console.WriteLine($"Error confirming tickets: {ex}");
        }
    }

    private async Task ConfirmSeatingOption()
    {
        if (selectedOption != null)
        {
            await JSRuntime.InvokeVoidAsync("hideModal", "seatingOptionsModal");
            await SelectSeatingOption(selectedOption);
        }
    }

    private async Task ConfirmSingleOption()
    {
        if (selectedOption != null)
        {
            await JSRuntime.InvokeVoidAsync("hideModal", "singleOptionConfirmModal");
            await SelectSeatingOption(selectedOption);
        }
    }

    private async Task SelectSeatingOption(string option)
    {
        try
        {
            if (pendingGroupOrder?.OrderToken == null)
            {
                SetMessage("No pending group order found.");
                return;
            }

            var request = new { OrderToken = pendingGroupOrder.OrderToken };
            var response = await Http.PostAsJsonAsync($"api/tickets/orders/select-option/{option}", request);

            if (response.IsSuccessStatusCode)
            {
                var result = await response.Content.ReadFromJsonAsync<OrderResponse>();
                orderToken = result.OrderToken;
                
                // Now we can add the selected seats
                if (result.SeatIds != null && result.SeatIds.Any())
                {
                    var selectedSeatsFromResponse = presentation.Rows
                        .SelectMany(r => r.Seats)
                        .Where(s => result.SeatIds.Contains(s.Id))
                        .ToList();

                    selectedSeats.Clear();
                    selectedSeats.AddRange(selectedSeatsFromResponse);
                    SetMessage($"Group order started with {selectedSeats.Count} seats selected.");
                    
                    // Initialize ticket types for all seats in the group order
                    foreach (var seat in selectedSeats)
                    {
                        if (!ticketTypes.ContainsKey(seat.Id))
                        {
                            ticketTypes.Add(seat.Id, "adult");
                        }
                    }
                }
            }

            // Load all seats to refresh the UI
            await LoadSeats();
        }
        catch (Exception ex)
        {
            SetMessage($"Error selecting seating option: {ex.Message}");
            Console.WriteLine($"Error selecting seating option: {ex.Message}");
        }
    }

    private async Task CancelOrder()
    {
        try
        {
            string? tokenToCancel = orderToken ?? pendingGroupOrder?.OrderToken;
            if (tokenToCancel != null)
            {
                // Hide any open modals
                showSeatSelectionModal = false;
                await JSRuntime.InvokeVoidAsync("hideModal", "seatingOptionsModal");
                await JSRuntime.InvokeVoidAsync("hideModal", "singleOptionConfirmModal");

                // Call the API to cancel the order
                var response = await Http.PostAsync($"api/tickets/orders/{tokenToCancel}/cancel", null);
                
                if (response.IsSuccessStatusCode)
                {
                    // Stop both timers
                    expirationTimer.Stop();
                    validationTimer.Stop();
                    orderExpirationTime = null;
                    
                    // Clear local state
                    orderToken = null;
                    pendingGroupOrder = null;
                    selectedSeats.Clear();
                    availableOptions = null;
                    selectedOption = null;
                    SetMessage("Order cancelled successfully.");

                    // Refresh the seats to show updated availability
                    await LoadSeats();
                    
                    // Go back to the seat selection modal
                    showSeatSelectionModal = true;
                }
                else
                {
                    var error = await response.Content.ReadAsStringAsync();
                    SetMessage($"Failed to cancel order: {error}");
                }
            }
            else
            {
                // If there's no active order yet, just show the modal again
                showSeatSelectionModal = true;
            }
        }
        catch (Exception ex)
        {
            SetMessage($"Error cancelling order: {ex.Message}");
            Console.WriteLine($"Error cancelling order: {ex}");
        }
    }

    private void SelectTicketType(int seatId, string ticketType)
    {
        if (ticketTypes.ContainsKey(seatId))
        {
            ticketTypes[seatId] = ticketType;
        }
        else
        {
            ticketTypes.Add(seatId, ticketType);
        }
        
        StateHasChanged();
    }
    
    private string GetTicketTypeName(string type)
    {
        return type switch
        {
            "adult" => "Adult",
            "child" => "Child",
            "senior" => "Senior",
            "student" => "Student",
            _ => "Regular"
        };
    }
    
    private decimal GetTicketTypePrice(string type)
    {
        return type switch
        {
            "adult" => 12.50m,
            "child" => 8.50m,
            "senior" => 10.50m,
            "student" => 9.50m,
            _ => 12.50m
        };
    }
    
    private decimal CalculateTotalPrice()
    {
        decimal total = 0;
        
        // Ensure we have ticket types for all selected seats
        foreach (var seat in selectedSeats)
        {
            string ticketType = ticketTypes.ContainsKey(seat.Id) ? ticketTypes[seat.Id] : "adult";
            
            if (!ticketTypes.ContainsKey(seat.Id))
            {
                ticketTypes.Add(seat.Id, ticketType);
            }
            
            total += GetTicketTypePrice(ticketType);
        }
        
        return total;
    }
    
    // When seats change, ensure we have ticket types for each seat
    protected override void OnParametersSet()
    {
        InitializeTicketTypes();
    }
    
    private void InitializeTicketTypes()
    {
        // Initialize default ticket types for all selected seats
        foreach (var seat in selectedSeats)
        {
            if (!ticketTypes.ContainsKey(seat.Id))
            {
                ticketTypes.Add(seat.Id, "adult");
            }
        }
        
        // Remove ticket types for seats that are no longer selected
        var seatIds = selectedSeats.Select(s => s.Id).ToList();
        var keysToRemove = ticketTypes.Keys.Where(k => !seatIds.Contains(k)).ToList();
        
        foreach (var key in keysToRemove)
        {
            ticketTypes.Remove(key);
        }
    }
    
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await JSRuntime.InvokeVoidAsync("initScrollTracking");
        }
    }
    
    [JSInvokable]
    public static Task UpdateProgressStep(int step)
    {
        if (_instance != null && _instance.activeStep != step)
        {
            _instance.activeStep = step;
            _instance.StateHasChanged();
        }
        return Task.CompletedTask;
    }
