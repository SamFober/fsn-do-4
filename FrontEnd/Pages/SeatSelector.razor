@page "/seat-selector/{presentationId:int}"

@using FrontEnd.Models
@using FrontEnd.Models.Responses
@using Microsoft.JSInterop
@using System.Timers

@implements IDisposable
@inject NavigationManager Navigation
@inject HttpClient Http
@inject IJSRuntime JSRuntime
@inject NavigationManager NavigationManager

<link href="css/seating.css" rel="stylesheet" />
<link href="css/modals.css" rel="stylesheet" />

<div class="cinema-container cinema-dark-mode" id="cinemaContainer">
    <div class="sticky-header-wrapper">
        <div class="sticky-progress-container">
            <div class="booking-progress-wrapper">
                <button @onclick="CancelOrder" class="cancel-button">
                    <span>← Cancel</span>
                </button>

                <div class="booking-progress">
                    <div class="progress-step @(activeStep == 1 ? "active" : "")">
                        <div class="step-circle">1</div>
                        <div class="step-label">Choose Seats</div>
                    </div>
                    <div class="progress-connector"></div>
                    <div class="progress-step @(activeStep == 2 ? "active" : "")">
                        <div class="step-circle">2</div>
                        <div class="step-label">Payment</div>
                    </div>
                    <div class="progress-connector"></div>
                    <div class="progress-step @(activeStep == 3 ? "active" : "")">
                        <div class="step-circle">3</div>
                        <div class="step-label">Confirmation</div>
                    </div>
                </div>

                @if (orderExpirationTime.HasValue)
                {
                    <div class="order-timer @(timeRemaining.TotalMinutes < 2 ? "order-timer-warning" : "")">
                        <div class="timer-content">
                            <div class="countdown">@(timeRemaining.Minutes.ToString("D2")):@(timeRemaining.Seconds.ToString("D2"))</div>
                        </div>
                    </div>
                }
            </div>
            <div class="sticky-title-container">
                <h3 class="cinema-title sticky-title">
                    @(presentation?.IsSecretMovie == true ? "Secret Movie" : (presentation?.Title ?? "Unknown Movie")) - @(presentation?.HallName ?? "Unknown Hall")
                </h3>
            </div>
        </div>
    </div>

    <div class="content-with-header-space">
        @if (message != null)
        {
            <div class="cinema-alert @(message.Contains("Error") || message.Contains("Failed") ? "cinema-alert-danger" : "cinema-alert-success") @(isMessageFading ? "fade-out" : "")" @key="message">
                <div class="cinema-alert-icon">
                    @if (message.Contains("Error") || message.Contains("Failed"))
                    {
                        <span>❌</span>
                    }
                    else
                    {
                        <span>✓</span>
                    }
                </div>
                <div class="cinema-alert-message">@message</div>
            </div>
        }

        @if (presentation == null)
        {
            <div class="text-center loading-container seat-selection-section">
                <h4>Loading all seats...</h4>
                <div class="spinner-border" role="status">
                    <span class="visually-hidden">Loading...</span>
                </div>
            </div>
        }
        else
        {
            @if (presentation.Rows.Count > 0)
            {
                <div class="cinema-layout seat-selection-section">
                    <div class="seating-container">
                        <div class="seat-map">
                            @foreach (var row in presentation.Rows.OrderBy(r => r.RowNumber))
                            {
                                <div class="seat-row">
                                    <div class="row-label">@row.RowNumber</div>
                                    <div class="seats">
                                        @foreach (var seat in row.Seats.OrderBy(s => s.SeatNumber))
                                        {
                                            var isSelected = selectedSeats.Any(s => s.Id == seat.Id);
                                            string seatClass = isSelected ? "seat-selected" : 
                                                               !seat.IsAvailable ? "seat-unavailable" : "seat-available";

                                            <div class="seat @seatClass" @onclick="() => SelectSeat(seat)" title="Row @row.RowNumber, Seat @seat.SeatNumber">
                                                <span class="seat-number">@seat.SeatNumber</span>
                                            </div>
                                        }
                                    </div>
                                </div>
                            }
                        </div>
                        <div class="screen-container">
                            <div class="screen">
                                <div class="screen-text">SCREEN</div>
                            </div>
                        </div>
                    </div>

                    <div class="seat-legend">
                        <div class="legend-item">
                            <div class="seat-sample seat-available"></div>
                            <span>Available</span>
                        </div>
                        <div class="legend-item">
                            <div class="seat-sample seat-selected"></div>
                            <span>Selected</span>
                        </div>
                        <div class="legend-item">
                            <div class="seat-sample seat-unavailable"></div>
                            <span>Unavailable</span>
                        </div>
                    </div>

                    @if (selectedSeats.Count > 0)
                    {
                        <div class="order-summary">
                            <div id="ticketTypeSection" class="ticket-type-section">
                                <h4>Select Ticket Types:</h4>
                                <p class="ticket-instruction-text">Please select a ticket type for each seat</p>

                                @for (int i = 0; i < selectedSeats.Count; i++)
                                {
                                    var seat = selectedSeats.OrderBy(s => s.RowNumber).ThenBy(s => s.SeatNumber).ElementAt(i);
                                    var index = i;

                                    <div class="ticket-type-row">
                                        <div class="ticket-seat-info">Row @seat.RowNumber, Seat @seat.SeatNumber</div>
                                        <div class="ticket-type-selector">
                                            <select class="form-select" value="@(ticketTypes.ContainsKey(seat.Id) ? ticketTypes[seat.Id] : "adult")" 
                                            @onchange="@(e => SelectTicketType(seat.Id, e.Value.ToString()))">
                                                <option value="adult">Adult - €@GetTicketTypePrice("adult")</option>
                                                <option value="child">Child - €@GetTicketTypePrice("child")</option>
                                                <option value="senior">Senior - €@GetTicketTypePrice("senior")</option>
                                                <option value="student">Student - €@GetTicketTypePrice("student")</option>
                                            </select>
                                            <select class="form-select" @onchange="@(e => SelectPopcornType(seat.Id, e.Value.ToString()))">
                                                <option value="">Concessions</option>
                                                @foreach (var item in concessions)
                                                {
                                                    <option value="@item.Id">@item.Name (€@item.Price.ToString("F2"))</option>
                                                }
                                            </select>
                                        </div>
                                    </div>
                                }

                                <div class="price-summary">
                                    <div class="price-details">
                                        @foreach (var ticketGroup in ticketTypes.GroupBy(t => t.Value).OrderBy(g => g.Key))
                                        {
                                            <div class="price-row">
                                                <span>@GetTicketTypeName(ticketGroup.Key) (@ticketGroup.Count())</span>
                                                <span>€@((GetTicketTypePrice(ticketGroup.Key) * ticketGroup.Count()).ToString("F2"))</span>
                                            </div>
                                        }
                                        @foreach (var popcornType in popcornTypes.GroupBy(t => t.Value))
                                        {
                                            <div class="price-row">
                                                <span>@GetConcessionTypeName(int.Parse(popcornType.Key)) (@popcornType.Count())</span>
                                                <span>€@(GetConcessionTypePrice(int.Parse(popcornType.Key)) * (popcornType.Count()))</span>
                                            </div>
                                        }
                                    </div>
                                    <div class="price-total">
                                        <span>Total</span>
                                        <span>€@CalculateTotalPrice().ToString("F2")</span>
                                    </div>
                                </div>
                            </div>

                            <div class="action-buttons">
                                <button @onclick="CancelOrder" class="cinema-btn cinema-btn-danger">Cancel Order</button>
                                <button @onclick="ConfirmTickets" class="cinema-btn cinema-btn-primary">Confirm Tickets</button>
                            </div>
                        </div>
                    }
                </div>
            }
        }
    </div>
</div>

<!-- Replace the fullscreen modal with an overlay modal -->
<div class="overlay-modal @(showSeatSelectionModal ? "show" : "")" id="seatSelectionModal">
    <div class="overlay-modal-content">
        <div class="overlay-modal-header">
            <h3 class="modal-title">Select Seats for @(presentation?.IsSecretMovie == true ? "Secret Movie" : (presentation?.Title ?? "Unknown Movie"))</h3>
        </div>
        <div class="overlay-modal-body">
            @if (!string.IsNullOrEmpty(groupOrderError))
            {
                <div class="cinema-alert cinema-alert-danger">
                    <div class="cinema-alert-icon">
                        <span>❌</span>
                    </div>
                    <div class="cinema-alert-message">@groupOrderError</div>
                </div>
            }

            <div class="overlay-form-container">
                <div class="form-group seat-selection-form">
                    <h2 class="seat-selection-title">How many seats would you like to book?</h2>
                    <div class="seat-counter">
                        <button class="btn-adjust" @onclick="DecrementSeats" disabled="@(numberOfSeats <= 1)">-</button>
                        <input type="number" class="form-control seat-count-input" id="numberOfSeats" @bind="numberOfSeats" min="1" max="@maxAvailableSeats" />
                        <button class="btn-adjust" @onclick="IncrementSeats" disabled="@(numberOfSeats >= maxAvailableSeats)">+</button>
                    </div>
                    <div class="seat-info">
                        <p>Maximum available: @maxAvailableSeats seats</p>
                    </div>
                </div>

                <div class="action-buttons overlay-modal-buttons">
                    <button @onclick="CancelOrder" class="cinema-btn cinema-btn-danger">Cancel Order</button>
                    <button @onclick="ProcessOrder" class="cinema-btn cinema-btn-primary continue-btn">Continue</button>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Add this modal for seating options -->
<div class="modal fade cinema-modal" id="seatingOptionsModal" data-bs-backdrop="static" data-bs-keyboard="false" tabindex="-1" aria-labelledby="seatingOptionsModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content cinema-modal-content">
            <div class="modal-header cinema-modal-header">
                <h5 class="modal-title">Select Seating Option</h5>
                <!-- No close button to force user decision -->
            </div>
            <div class="modal-body cinema-modal-body">
                @if (availableOptions != null)
                {
                    @foreach (var option in availableOptions)
                    {
                        <label class="cinema-radio-option mb-3 @(selectedOption == option.Key ? "selected" : "")">
                            <input class="cinema-radio-input" type="radio" name="seatingOption" 
                            value="@option.Key" @onchange="@(e => selectedOption = option.Key)" 
                            checked="@(selectedOption == option.Key)" />
                            <div class="cinema-radio-content">
                                <span class="cinema-radio-title">@option.Value.Description</span>
                                <div class="cinema-option-details">
                                    @foreach (var group in option.Value.Groups)
                                    {
                                        <div>@group.Description</div>
                                    }
                                </div>
                            </div>
                        </label>
                    }
                }
            </div>
            <div class="modal-footer cinema-modal-footer">
                <button type="button" class="cinema-btn cinema-btn-danger" @onclick="CancelOrder">Cancel Order</button>
                <button type="button" class="cinema-btn cinema-btn-primary" @onclick="ConfirmSeatingOption">Confirm Selection</button>
            </div>
        </div>
    </div>
</div>

<!-- Add this modal for single option confirmation -->
<div class="modal fade cinema-modal" id="singleOptionConfirmModal" data-bs-backdrop="static" data-bs-keyboard="false" tabindex="-1" aria-labelledby="singleOptionConfirmModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content cinema-modal-content">
            <div class="modal-header cinema-modal-header">
                <h5 class="modal-title">Confirm Seating Arrangement</h5>
                <!-- No close button to force user decision -->
            </div>
            <div class="modal-body cinema-modal-body">
                @if (singleOptionMessage != null)
                {
                    <p class="cinema-message">@singleOptionMessage</p>
                }
            </div>
            <div class="modal-footer cinema-modal-footer">
                <button type="button" class="cinema-btn cinema-btn-danger" @onclick="CancelOrder">Cancel Order</button>
                <button type="button" class="cinema-btn cinema-btn-primary" @onclick="ConfirmSingleOption">Confirm</button>
            </div>
        </div>
    </div>
</div>

<div class="modal fade cinema-modal" id="numpadModal" tabindex="-1" aria-labelledby="numpadModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content cinema-modal-content">
            <div class="modal-header cinema-modal-header">
                <h5 class="modal-title">Total: €@CalculateTotalPrice().ToString("F2"). Please enter your PIN</h5>
            </div>
            <div class="modal-body cinema-modal-body cinema-modal-body-numpad">
                <link href="https://fonts.googleapis.com/icon?family=Material+Icons" rel="stylesheet">
                <div class="numpad-container">
                    <div class="numpad-display">@numpadInputValue</div>
                    <div class="numpad-grid">
                        @foreach (var num in new[] { "1", "2", "3", "4", "5", "6", "7", "8", "9" })
                        {
                            <button class="numpad-button" @onclick="() => NumpadAddNumber(num)">@num</button>
                        }
                        <button class="numpad-button" @onclick="@(() => NumpadAddNumber("0"))">0</button>
                        <button class="numpad-button" @onclick="NumpadRemoveNumber"><i class="material-icons">&#xe14a;</i></button>
                        <button class="numpad-button numpad-clear" @onclick="NumpadClearInput">AC</button>
                    </div>
                </div>
            </div>
            <div class="modal-footer cinema-modal-footer">
                <!-- Conditionally change if PIN is confirmed -->
                @if (!numpadPinConfirmed)
                {
                    <button type="button" class="cinema-btn cinema-btn-danger" @onclick="CancelOrder">Cancel Order</button>
                    <button type="button" class="cinema-btn cinema-btn-primary" @onclick="NumpadConfirmInput">Confirm PIN</button>
                }
                else
                {
                    <button type="button" class="cinema-btn cinema-btn-primary" @onclick="GetTickets">Get tickets</button>    
                }
            </div>
        </div>
    </div>
</div>

<style>
    /* Numpad modal */
    .numpad-container {
    width: 250px;
    background: transparent;
    color: white;
    border-radius: 10px;
    padding: 15px;
    text-align: center;
    box-shadow: 0 4px 10px rgba(0, 0, 0, 0.3);
    }

    .numpad-display {
    height: 50px;
