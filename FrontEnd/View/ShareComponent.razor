@inject NavigationManager NavigationManager
@inject IJSRuntime JS

<button @onclick="DeelPagina">📢</button>

<script>
    function shareContent() {
        if (navigator.share) {
            navigator.share({
                title: "Check this!",
                text: "Cinemagia",
                url: window.location.href
            })
            .then(() => console.log("Succesvol gedeeld!"))
            .catch((error) => console.error("Fout bij delen:", error));
        } else {
            // Fallback: Copy link to clipboard
            navigator.clipboard.writeText(window.location.href)
            .then(() => alert("Link gekopieerd naar klembord!"))
            .catch((err) => console.error("Fout bij kopiëren:", err));
        }
    }

</script>

@code {
    private async Task DeelPagina()
    {   
        await JS.InvokeVoidAsync("shareContent",
            "Check out this page",
            "I found something interesting!",
            NavigationManager.Uri);
    }
}
